{
  "$schema": "https://mintlify.com/docs/schema.json",
  "theme": "mint",
  "name": "Edge Docs",
  "logo": {
    "dark": "/logo/edge-dark.svg",
    "light": "/logo/edge-light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#F5F4F2",
    "light": "#0a0e19",
    "dark": "#F5F4F2",
    "background": {
      "dark": "#0D0C0B",
      "light": "#F9FAFB"
    }
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": false
  },
  "rounded": "default",
  "font": {
    "headings": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "credits",
              "errors"
            ]
          },
          {
            "group": "Dashboard",
            "pages": [
              "dashboard/overview",
              "dashboard/api-keys",
              "dashboard/playground",
              "dashboard/team",
              "dashboard/billing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "IBAN Validation",
            "pages": [
              "api-reference/iban/validate",
              "api-reference/iban/validate-basic",
              "api-reference/iban/bulk-validate"
            ]
          },
          {
            "group": "Sanctions Screening",
            "pages": [
              "api-reference/sanctions/screen",
              "api-reference/sanctions/stats"
            ]
          },
          {
            "group": "Exchange Rates",
            "pages": [
              "api-reference/fx/latest",
              "api-reference/fx/historical",
              "api-reference/fx/convert",
              "api-reference/fx/currencies"
            ]
          },
          {
            "group": "Bank Directory",
            "pages": [
              "api-reference/bank/bic-lookup",
              "api-reference/bank/by-country",
              "api-reference/bank/search",
              "api-reference/bank/countries"
            ]
          },
          {
            "group": "Commercial Registry",
            "pages": [
              "api-reference/cr/lookup",
              "api-reference/cr/search"
            ]
          },
          {
            "group": "Country Data",
            "pages": [
              "api-reference/country/lookup",
              "api-reference/country/list",
              "api-reference/country/search",
              "api-reference/country/by-currency",
              "api-reference/country/by-calling-code",
              "api-reference/country/by-region"
            ]
          },
          {
            "group": "Email Validation",
            "pages": [
              "api-reference/email/validate"
            ]
          },
          {
            "group": "Phone Validation",
            "pages": [
              "api-reference/phone/validate"
            ]
          }
        ]
      }
    ]
  },
  "topbarLinks": [
    {
      "name": "Support",
      "url": "mailto:support@edge.bh"
    }
  ],
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://app.edge.bh"
  },
  "footerSocials": {
    "x": "https://x.com/use_edge",
    "github": "https://github.com/edge-holding",
    "instagram": "https://www.instagram.com/use.edge",
    "linkedin": "https://www.linkedin.com/company/edge-holding"
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "cursor"]
  }
}
